---
import '../styles/global.css';
import { profile } from '../data/profile';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${profile.name} — 一方天地`,
  description = `${profile.name} 的个人空间 · 黄昏书房`,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN" data-theme={profile.defaultTheme} data-palette={profile.defaultPalette}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- 字体:Fraunces 做标题,Inter 做正文,加载失败优雅回退到系统字体 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&family=Inter:wght@300..600&display=swap"
      rel="stylesheet"
    />

    <!-- 在页面绘制前就应用记住的配色 / 明暗,消除刷新时的闪烁 -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          var p = localStorage.getItem('palette');
          if (t) document.documentElement.setAttribute('data-theme', t);
          if (p) document.documentElement.setAttribute('data-palette', p);
        } catch (e) {}
      })();
    </script>
  </head>

  <body>
    <div class="spotlight" aria-hidden="true"></div>

    <button class="theme-toggle" id="themeToggle" aria-label="切换明暗">
      <!-- 太阳(浅色时显示) -->
      <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
      </svg>
      <!-- 月亮(深色时显示) -->
      <svg class="moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
      </svg>
    </button>

    <!-- 配色切换器:平时收起为一个调色盘图标,点击才优雅展开 -->
    <div class="palette" id="palette">
      <button class="palette-trigger" id="paletteTrigger" aria-label="配色方案" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2a10 10 0 1 0 0 20c1 0 1.8-.8 1.8-1.8 0-.5-.2-.9-.5-1.2-.3-.3-.5-.7-.5-1.2 0-1 .8-1.8 1.8-1.8H16a6 6 0 0 0 6-6c0-4.9-4.5-8.2-10-8.2Z" />
          <circle cx="7.5" cy="11.5" r="1.1" fill="currentColor" stroke="none" />
          <circle cx="11.5" cy="7.5" r="1.1" fill="currentColor" stroke="none" />
          <circle cx="16" cy="9.5" r="1.1" fill="currentColor" stroke="none" />
        </svg>
      </button>
      <div class="palette-panel" id="palettePanel" role="group" aria-label="配色方案">
        <span class="swatch" data-p="amber" data-name="黄昏书房" title="黄昏书房 · 琥珀金"></span>
        <span class="swatch" data-p="pine" data-name="松林雾隐" title="松林雾隐 · 墨绿暖灰"></span>
        <span class="swatch" data-p="terra" data-name="赤陶暮色" title="赤陶暮色 · 陶土赭石"></span>
        <span class="swatch" data-p="indigo" data-name="靛蓝旧纸" title="靛蓝旧纸 · 沉静书卷"></span>
        <span class="swatch" data-p="heather" data-name="石楠紫灰" title="石楠紫灰 · 雾霾紫"></span>
        <span class="sep" aria-hidden="true"></span>
        <span class="swatch" data-p="ink" data-name="墨白宣纸" title="墨白宣纸 · 朱砂点睛"></span>
        <span class="swatch" data-p="stone" data-name="裸灰画廊" title="裸灰画廊 · 香槟铜"></span>
        <span class="swatch" data-p="olive" data-name="暗橄榄" title="暗橄榄 · 暖卡其"></span>
        <span class="swatch" data-p="onyx" data-name="碳金" title="碳金 · 高对比哑金"></span>
        <span class="sep" aria-hidden="true"></span>
        <span class="swatch" data-p="claude" data-name="Claude" title="Claude · 陶土暖橙"></span>
        <span class="swatch" data-p="openai" data-name="OpenAI" title="OpenAI · 墨黑薄荷"></span>
      </div>
    </div>

    <div class="wrap">
      <div class="layout">
        <slot />
      </div>
    </div>

    <script>
      // ===== 明暗 + 配色切换(均记忆选择)=====
      const root = document.documentElement;
      const toggle = document.getElementById('themeToggle')!;

      // 明暗切换(初始值已由 head 内联脚本应用,这里只处理点击)
      toggle.addEventListener('click', () => {
        const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        root.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });

      // 配色切换:点色卡换整站配色
      const palette = document.getElementById('palette')!;
      const paletteTrigger = document.getElementById('paletteTrigger')!;
      const swatches = [...document.querySelectorAll<HTMLElement>('.swatch')];
      function syncSwatchActive() {
        const cur = root.getAttribute('data-palette');
        swatches.forEach((s) => s.classList.toggle('active', s.dataset.p === cur));
      }
      swatches.forEach((s) => {
        s.addEventListener('click', () => {
          const p = s.dataset.p!;
          root.setAttribute('data-palette', p);
          localStorage.setItem('palette', p);
          syncSwatchActive();
        });
      });
      syncSwatchActive();

      // 配色面板:点调色盘图标展开 / 收起,点面板外或按 Esc 收起
      function setPaletteOpen(open: boolean) {
        palette.classList.toggle('open', open);
        paletteTrigger.setAttribute('aria-expanded', open ? 'true' : 'false');
      }
      paletteTrigger.addEventListener('click', (e) => {
        e.stopPropagation();
        setPaletteOpen(!palette.classList.contains('open'));
      });
      document.addEventListener('click', (e) => {
        if (!palette.contains(e.target as Node)) setPaletteOpen(false);
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') setPaletteOpen(false);
      });

      // ===== 鼠标暖光晕跟随 =====
      const spotlight = document.querySelector<HTMLElement>('.spotlight')!;
      let tx = 0, ty = 0, cx = 0, cy = 0;
      window.addEventListener('mousemove', (e) => { tx = e.clientX; ty = e.clientY; });
      (function loop() {
        cx += (tx - cx) * 0.12;
        cy += (ty - cy) * 0.12;
        spotlight.style.setProperty('--mx', cx + 'px');
        spotlight.style.setProperty('--my', cy + 'px');
        requestAnimationFrame(loop);
      })();

      // ===== 滚动导航联动高亮 =====
      const navLinks = [...document.querySelectorAll<HTMLElement>('.nav-link')];
      const sections = [...document.querySelectorAll<HTMLElement>('section[id]')];
      const spy = new IntersectionObserver((entries) => {
        entries.forEach((en) => {
          if (en.isIntersecting) {
            const id = en.target.id;
            navLinks.forEach((l) =>
              l.classList.toggle('active', l.getAttribute('href') === '#' + id)
            );
          }
        });
      }, { rootMargin: '-45% 0px -50% 0px' });
      sections.forEach((s) => spy.observe(s));

      // ===== 进场 reveal =====
      const revealer = new IntersectionObserver((entries) => {
        entries.forEach((en) => {
          if (en.isIntersecting) { en.target.classList.add('in'); revealer.unobserve(en.target); }
        });
      }, { threshold: 0.15 });
      document.querySelectorAll<HTMLElement>('[data-reveal]').forEach((el, i) => {
        el.style.transitionDelay = (i % 4) * 0.06 + 's';
        revealer.observe(el);
      });

      // ===== 博文:点标题原地丝滑展开 / 折叠(纯 CSS grid 过渡驱动,JS 只切 class)=====
      document.querySelectorAll<HTMLElement>('.post-head').forEach((head) => {
        head.addEventListener('click', () => {
          const article = head.closest('.post')!;
          const open = article.classList.toggle('open');
          head.setAttribute('aria-expanded', open ? 'true' : 'false');
        });
      });

      // ===== 实时 GitHub 星标:页面打开即同步,网页随星数变化 =====
      // 策略:本地缓存 1 小时 → 过期则请求 GitHub 公开 API → 失败回退到写死的已知星数,绝不空白
      (function syncStars() {
        const CACHE_TTL = 60 * 60 * 1000; // 1 小时
        document.querySelectorAll<HTMLElement>('.card.project[data-repo]').forEach(async (card) => {
          const repo = card.getAttribute('data-repo');
          const numEl = card.querySelector<HTMLElement>('.star-num');
          const badge = card.querySelector<HTMLElement>('.tag.star');
          if (!repo || !numEl) return;

          const cacheKey = 'stars:' + repo;
          try {
            const cached = JSON.parse(localStorage.getItem(cacheKey) || 'null');
            if (cached && Date.now() - cached.t < CACHE_TTL) {
              render(cached.n);
              return;
            }
          } catch (e) { /* 缓存损坏,忽略,走网络 */ }

          badge && badge.classList.add('updating');
          try {
            const res = await fetch('https://api.github.com/repos/' + repo, {
              headers: { 'Accept': 'application/vnd.github+json' },
            });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            const data = await res.json();
            const n = data.stargazers_count;
            if (typeof n === 'number') {
              localStorage.setItem(cacheKey, JSON.stringify({ n, t: Date.now() }));
              render(n);
            }
          } catch (e: any) {
            console.warn('星标同步失败(已回退到本地数字):', repo, e.message);
          } finally {
            badge && badge.classList.remove('updating');
          }

          function render(n: number) {
            const old = parseInt(numEl!.textContent || '', 10);
            numEl!.textContent = String(n);
            if (!Number.isNaN(old) && old !== n) {
              numEl!.classList.remove('bump');
              void numEl!.offsetWidth;
              numEl!.classList.add('bump');
            }
          }
        });
      })();
    </script>
  </body>
</html>
