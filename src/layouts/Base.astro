---
import '../styles/global.css';
import { profile as fallbackProfile, type Profile } from '../data/profile';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  bodyClass?: string;
  layout?: 'split' | 'single';
  showReadingProgress?: boolean;
  ogType?: 'website' | 'article';
  profile?: Profile;
}

const {
  profile = fallbackProfile,
} = Astro.props;

const {
  title = `${profile.name} — 一方天地`,
  description = `${profile.name} 的个人空间 · 黄昏书房`,
  image,
  canonical,
  bodyClass = '',
  layout = 'split',
  showReadingProgress = false,
  ogType = 'website',
} = Astro.props;

const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = canonical ? new URL(canonical, siteUrl).toString() : new URL(Astro.url.pathname, siteUrl).toString();
const imageUrl = image ? new URL(image, siteUrl).toString() : undefined;
---

<!DOCTYPE html>
<html lang="zh-CN" data-theme={profile.defaultTheme} data-palette={profile.defaultPalette}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta name="twitter:card" content={imageUrl ? 'summary_large_image' : 'summary'} />
    <link rel="icon" href="/assets/loven7-logo.svg" type="image/svg+xml" />

    <!-- 字体:Fraunces 做标题,Inter 做正文,加载失败优雅回退到系统字体 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&family=Inter:wght@300..600&display=swap"
      rel="stylesheet"
    />

    <!-- 在页面绘制前就应用记住的配色 / 明暗,消除刷新时的闪烁 -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          var p = localStorage.getItem('palette');
          if (t) document.documentElement.setAttribute('data-theme', t);
          if (p) document.documentElement.setAttribute('data-palette', p);
        } catch (e) {}
      })();
    </script>
  </head>

  <body class={bodyClass || undefined}>
    {showReadingProgress && <div class="reading-progress" id="readingProgress" aria-hidden="true"></div>}
    <div class="spotlight" aria-hidden="true"></div>

    <!-- 配色切换器:平时收起为一个调色盘图标,点击才优雅展开 -->
    <div class="palette" id="palette">
      <button class="palette-trigger" id="paletteTrigger" aria-label="配色方案" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2a10 10 0 1 0 0 20c1 0 1.8-.8 1.8-1.8 0-.5-.2-.9-.5-1.2-.3-.3-.5-.7-.5-1.2 0-1 .8-1.8 1.8-1.8H16a6 6 0 0 0 6-6c0-4.9-4.5-8.2-10-8.2Z" />
          <circle cx="7.5" cy="11.5" r="1.1" fill="currentColor" stroke="none" />
          <circle cx="11.5" cy="7.5" r="1.1" fill="currentColor" stroke="none" />
          <circle cx="16" cy="9.5" r="1.1" fill="currentColor" stroke="none" />
        </svg>
      </button>
      <div class="palette-panel" id="palettePanel" role="group" aria-label="配色方案">
        <button class="theme-toggle" id="themeToggle" type="button" aria-label="切换明暗" title="切换明暗">
          <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
            <circle cx="12" cy="12" r="4" />
            <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
          </svg>
          <svg class="moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
          </svg>
        </button>
        <button class="swatch" type="button" data-p="amber" data-name="黄昏书房" aria-label="黄昏书房" title="黄昏书房 · 琥珀金"></button>
        <button class="swatch" type="button" data-p="pine" data-name="松林雾隐" aria-label="松林雾隐" title="松林雾隐 · 墨绿暖灰"></button>
        <button class="swatch" type="button" data-p="terra" data-name="赤陶暮色" aria-label="赤陶暮色" title="赤陶暮色 · 陶土赭石"></button>
        <button class="swatch" type="button" data-p="indigo" data-name="靛蓝旧纸" aria-label="靛蓝旧纸" title="靛蓝旧纸 · 沉静书卷"></button>
        <button class="swatch" type="button" data-p="heather" data-name="石楠紫灰" aria-label="石楠紫灰" title="石楠紫灰 · 雾霾紫"></button>
        <button class="swatch" type="button" data-p="ink" data-name="墨白宣纸" aria-label="墨白宣纸" title="墨白宣纸 · 朱砂点睛"></button>
        <button class="swatch" type="button" data-p="stone" data-name="裸灰画廊" aria-label="裸灰画廊" title="裸灰画廊 · 香槟铜"></button>
        <button class="swatch" type="button" data-p="olive" data-name="暗橄榄" aria-label="暗橄榄" title="暗橄榄 · 暖卡其"></button>
        <button class="swatch" type="button" data-p="onyx" data-name="碳金" aria-label="碳金" title="碳金 · 高对比哑金"></button>
        <button class="swatch" type="button" data-p="claude" data-name="Claude" aria-label="Claude" title="Claude · 陶土暖橙"></button>
        <button class="swatch" type="button" data-p="openai" data-name="OpenAI" aria-label="OpenAI" title="OpenAI · 墨黑薄荷"></button>
      </div>
    </div>

    <div class="wrap">
      <div class={`layout layout-${layout}`}>
        <slot />
      </div>
    </div>

    <script>
      const root = document.documentElement;
      const storage = {
        get(key) {
          try { return localStorage.getItem(key); } catch { return null; }
        },
        set(key, value) {
          try { localStorage.setItem(key, value); } catch {}
        },
        json(key) {
          try { return JSON.parse(localStorage.getItem(key) || 'null'); } catch { return null; }
        },
      };

      const themeToggle = document.getElementById('themeToggle');
      const palette = document.getElementById('palette');
      const paletteTrigger = document.getElementById('paletteTrigger');
      const swatches = Array.from(document.querySelectorAll('.swatch'));

      function syncThemeToggleLabel() {
        if (!themeToggle) return;
        const label = root.getAttribute('data-theme') === 'dark' ? '切换到浅色模式' : '切换到深色模式';
        themeToggle.setAttribute('aria-label', label);
        themeToggle.setAttribute('title', label);
      }

      function syncSwatchActive() {
        const current = root.getAttribute('data-palette');
        swatches.forEach((swatch) => {
          const active = swatch.getAttribute('data-p') === current;
          swatch.classList.toggle('active', active);
          swatch.setAttribute('aria-pressed', active ? 'true' : 'false');
        });
      }

      themeToggle?.addEventListener('click', () => {
        const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        root.setAttribute('data-theme', next);
        storage.set('theme', next);
        syncThemeToggleLabel();
      });

      swatches.forEach((swatch) => {
        swatch.addEventListener('click', () => {
          const next = swatch.getAttribute('data-p');
          if (!next) return;
          root.setAttribute('data-palette', next);
          storage.set('palette', next);
          syncSwatchActive();
        });
      });

      function setPaletteOpen(open) {
        if (!palette || !paletteTrigger) return;
        palette.classList.toggle('open', open);
        paletteTrigger.setAttribute('aria-expanded', open ? 'true' : 'false');
      }

      paletteTrigger?.addEventListener('click', (event) => {
        event.stopPropagation();
        setPaletteOpen(!palette?.classList.contains('open'));
      });
      document.addEventListener('click', (event) => {
        if (palette && !palette.contains(event.target)) setPaletteOpen(false);
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') setPaletteOpen(false);
      });

      syncThemeToggleLabel();
      syncSwatchActive();

      const spotlight = document.querySelector('.spotlight');
      const canTrackPointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
      if (spotlight && canTrackPointer) {
        let tx = 0, ty = 0, cx = 0, cy = 0;
        window.addEventListener('mousemove', (event) => {
          tx = event.clientX;
          ty = event.clientY;
        }, { passive: true });
        (function loop() {
          cx += (tx - cx) * 0.12;
          cy += (ty - cy) * 0.12;
          spotlight.style.setProperty('--mx', cx + 'px');
          spotlight.style.setProperty('--my', cy + 'px');
          requestAnimationFrame(loop);
        })();
      }

      const navLinks = Array.from(document.querySelectorAll('.nav-link'));
      const sections = Array.from(document.querySelectorAll('section[id]'));
      if ('IntersectionObserver' in window) {
        const spy = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const id = entry.target.id;
            navLinks.forEach((link) => {
              link.classList.toggle('active', link.getAttribute('href') === '#' + id);
            });
          });
        }, { rootMargin: '-45% 0px -50% 0px' });
        sections.forEach((section) => spy.observe(section));

        const revealer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('in');
            revealer.unobserve(entry.target);
          });
        }, { threshold: 0.15 });
        document.querySelectorAll('[data-reveal]').forEach((el, index) => {
          el.style.transitionDelay = (index % 4) * 0.06 + 's';
          revealer.observe(el);
        });
      } else {
        document.querySelectorAll('[data-reveal]').forEach((el) => el.classList.add('in'));
      }

      document.querySelectorAll('.post-head[aria-expanded]').forEach((head) => {
        head.addEventListener('click', () => {
          const article = head.closest('.post');
          if (!article) return;
          const open = article.classList.toggle('open');
          head.setAttribute('aria-expanded', open ? 'true' : 'false');
        });
      });

      (function syncStars() {
        const CACHE_TTL = 60 * 60 * 1000;
        document.querySelectorAll('.card.project[data-repo]').forEach(async (card) => {
          const repo = card.getAttribute('data-repo');
          const numEl = card.querySelector('.star-num');
          const badge = card.querySelector('.tag.star');
          if (!repo || !numEl) return;

          const cacheKey = 'stars:' + repo;
          const cached = storage.json(cacheKey);
          if (cached && Date.now() - cached.t < CACHE_TTL) {
            render(cached.n);
            return;
          }

          badge?.classList.add('updating');
          try {
            const res = await fetch('https://api.github.com/repos/' + repo, {
              headers: { 'Accept': 'application/vnd.github+json' },
            });
            if (!res.ok) throw new Error('HTTP ' + res.status);
            const data = await res.json();
            const n = data.stargazers_count;
            if (typeof n === 'number') {
              storage.set(cacheKey, JSON.stringify({ n, t: Date.now() }));
              render(n);
            }
          } catch (error) {
            console.warn('星标同步失败(已回退到本地数字):', repo, error);
          } finally {
            badge?.classList.remove('updating');
          }

          function render(n) {
            const old = parseInt(numEl.textContent || '', 10);
            numEl.textContent = String(n);
            if (!Number.isNaN(old) && old !== n) {
              numEl.classList.remove('bump');
              void numEl.offsetWidth;
              numEl.classList.add('bump');
            }
          }
        });
      })();

      const readingProgress = document.getElementById('readingProgress');
      if (readingProgress) {
        const updateReadingProgress = () => {
          const scrollable = document.documentElement.scrollHeight - window.innerHeight;
          const progress = scrollable > 0 ? window.scrollY / scrollable : 0;
          readingProgress.style.transform = 'scaleX(' + Math.min(1, Math.max(0, progress)) + ')';
        };

        updateReadingProgress();
        window.addEventListener('scroll', updateReadingProgress, { passive: true });
        window.addEventListener('resize', updateReadingProgress);
      }
    </script>
  </body>
</html>
