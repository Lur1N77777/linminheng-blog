---
const title = '内容管理 · 一方天地';
const passwordHash = 'd06ac7d1744a8b201b4dd97e960ae84ef4526e412ca828377850d8a44da45c81';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: dark;
        --bg: #11100e;
        --panel: #181612;
        --panel-strong: #201d18;
        --line: rgba(244, 234, 220, 0.14);
        --text: #f4eadc;
        --muted: rgba(244, 234, 220, 0.64);
        --faint: rgba(244, 234, 220, 0.42);
        --accent: #d9a860;
        --accent-strong: #d9a860;
        --danger: #ffb0a6;
        --radius: 8px;
        font-family:
          Inter,
          ui-sans-serif,
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        min-height: 100%;
        margin: 0;
      }

      body {
        display: grid;
        place-items: center;
        min-height: 100dvh;
        overflow-x: hidden;
        background: var(--bg);
        color: var(--text);
      }

      body.unlocked {
        display: block;
        min-width: 0;
        min-height: 100dvh;
        background: #0f0f0f;
      }

      .gate {
        width: min(92vw, 420px);
        padding: 1.15rem;
      }

      .gate-card {
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: var(--panel);
        box-shadow: none;
      }

      .gate-head {
        padding: 1.35rem 1.35rem 1rem;
        border-bottom: 1px solid rgba(247, 241, 230, 0.1);
      }

      .eyebrow {
        margin: 0 0 0.5rem;
        color: var(--accent-strong);
        font-size: 0.74rem;
        font-weight: 600;
        letter-spacing: 0;
      }

      h1 {
        margin: 0;
        font-size: clamp(1.55rem, 5vw, 2.1rem);
        font-weight: 520;
        letter-spacing: 0;
      }

      .desc {
        margin: 0.72rem 0 0;
        color: var(--muted);
        font-size: 0.92rem;
        line-height: 1.75;
      }

      .gate-form {
        display: grid;
        gap: 0.85rem;
        padding: 1.1rem 1.35rem 1.35rem;
      }

      .gate label {
        display: grid;
        gap: 0.45rem;
        color: var(--faint);
        font-size: 0.78rem;
      }

      .gate input,
      .gate button {
        width: 100%;
        min-height: 46px;
        border-radius: var(--radius);
        font: inherit;
      }

      .gate input {
        border: 1px solid rgba(247, 241, 230, 0.18);
        background: #11100e;
        color: var(--text);
        font-size: 16px !important;
        line-height: 1.2;
        outline: none;
        padding: 0 0.85rem;
        transition:
          border-color 180ms ease,
          background 180ms ease;
      }

      .gate input:focus {
        border-color: rgba(240, 199, 131, 0.72);
        background: #14120f;
      }

      .gate button {
        border: 1px solid color-mix(in srgb, var(--accent) 72%, var(--line));
        background: var(--accent);
        color: #17100a;
        cursor: pointer;
        font-size: 0.95rem;
        font-weight: 650;
        transition:
          transform 180ms ease,
          border-color 180ms ease,
          background 180ms ease;
      }

      .gate button:hover {
        background: color-mix(in srgb, var(--accent) 88%, #11100e);
        border-color: var(--accent);
        transform: translateY(-1px);
      }

      .gate button:disabled {
        cursor: wait;
        opacity: 0.6;
        transform: none;
      }

      body.unlocked {
        --sui-primary-accent-color: #d9a860 !important;
        --sui-primary-accent-hover-color: #c79652 !important;
        --sui-primary-background-color: #11100e !important;
        --sui-secondary-background-color: #181612 !important;
        --sui-tertiary-background-color: #201d18 !important;
        --sui-primary-foreground-color: #f4eadc !important;
        --sui-secondary-foreground-color: rgba(244, 234, 220, 0.68) !important;
        --sui-primary-border-color: rgba(244, 234, 220, 0.14) !important;
        --sui-control-medium-border-radius: 8px !important;
        --sui-button-medium-border-radius: 8px !important;
      }

      body.unlocked *,
      body.unlocked *::before,
      body.unlocked *::after {
        box-shadow: none !important;
        text-shadow: none !important;
      }

      body.unlocked button,
      body.unlocked .sui.button,
      body.unlocked [role="button"] {
        background-image: none !important;
        filter: none !important;
      }

      body.unlocked .sui.button.primary,
      body.unlocked button.primary,
      body.unlocked button[data-variant="primary"] {
        border-color: color-mix(in srgb, #d9a860 72%, rgba(244, 234, 220, 0.14)) !important;
        background-color: #d9a860 !important;
        color: #17100a !important;
      }

      body.unlocked button.sui.button.secondary,
      body.unlocked .sui.button.secondary {
        border-color: rgba(244, 234, 220, 0.18) !important;
        background-color: #181612 !important;
        color: rgba(244, 234, 220, 0.82) !important;
      }

      body.unlocked button.sui.button.primary *,
      body.unlocked .sui.button.primary * {
        color: #17100a !important;
      }

      body.unlocked button.sui.button.secondary *,
      body.unlocked .sui.button.secondary * {
        color: rgba(244, 234, 220, 0.82) !important;
      }

      body.unlocked img.logo[src^="data:image/svg+xml"] {
        display: none !important;
      }

      .status {
        min-height: 1.3em;
        margin: 0;
        color: var(--faint);
        font-size: 0.8rem;
        line-height: 1.6;
      }

      .status.error {
        color: var(--danger);
      }

      .cms-loading {
        display: none;
        min-height: 100vh;
        min-height: 100dvh;
        place-items: center;
        color: var(--muted);
        font-size: 0.92rem;
      }

      body.loading-cms .gate {
        display: none;
      }

      body.cms-ready .gate {
        display: none;
      }

      body.loading-cms .cms-loading {
        display: grid;
      }

      @media (max-width: 520px) {
        body {
          align-items: start;
          padding-top: max(1rem, env(safe-area-inset-top));
          padding-bottom: max(1rem, env(safe-area-inset-bottom));
        }

        body.unlocked,
        body.loading-cms,
        body.cms-ready {
          padding: 0;
        }

        .gate {
          width: 100%;
          padding: 0.85rem;
        }

        .gate-card {
          margin: 0 auto;
          max-width: 28rem;
        }

        .gate-head,
        .gate-form {
          padding-left: 0.95rem;
          padding-right: 0.95rem;
        }

        .gate-head {
          padding-top: 1.1rem;
        }

        .gate-form {
          gap: 0.75rem;
          padding-bottom: 1.05rem;
        }

        .desc {
          font-size: 0.88rem;
          line-height: 1.68;
        }
      }
    </style>
  </head>
  <body>
    <main class="gate" data-gate>
      <section class="gate-card" aria-labelledby="admin-title">
        <div class="gate-head">
          <p class="eyebrow">Admin</p>
          <h1 id="admin-title">内容管理</h1>
          <p class="desc">输入后台入口密码后进入内容编辑器。保存文章、项目和个人资料时仍需要 GitHub 授权。</p>
        </div>

        <form class="gate-form" data-form>
          <label>
            管理员密码
            <input data-password type="password" autocomplete="current-password" placeholder="输入后台密码" />
          </label>
          <button data-submit type="submit">进入后台</button>
          <p class="status" data-status aria-live="polite"></p>
        </form>
      </section>
    </main>

    <div class="cms-loading" data-loading>正在进入内容管理...</div>

    <script define:vars={{ passwordHash }} is:inline>
      const sessionKey = 'yftd-admin-unlocked';
      const authBridgeKey = 'sveltia-cms-auth-message:github';
      const form = document.querySelector('[data-form]');
      const input = document.querySelector('[data-password]');
      const submit = document.querySelector('[data-submit]');
      const status = document.querySelector('[data-status]');

      async function sha256(text) {
        const bytes = new TextEncoder().encode(text);
        const digest = await crypto.subtle.digest('SHA-256', bytes);
        return Array.from(new Uint8Array(digest))
          .map((byte) => byte.toString(16).padStart(2, '0'))
          .join('');
      }

      function setStatus(message, isError = false) {
        if (!status) return;
        status.textContent = message;
        status.classList.toggle('error', isError);
      }

      function loadCms() {
        document.body.classList.add('loading-cms', 'unlocked');
        installCmsTheme();
        relayStoredAuthMessage();
        const script = document.createElement('script');
        script.src = 'https://unpkg.com/@sveltia/cms/dist/sveltia-cms.js';
        script.async = true;
        script.addEventListener('load', () => {
          document.body.classList.remove('loading-cms');
          document.body.classList.add('cms-ready');
          setTimeout(installCmsTheme, 0);
          setTimeout(installCmsTheme, 800);
          relayStoredAuthMessage();
        });
        script.addEventListener('error', () => {
          document.body.classList.remove('loading-cms', 'cms-ready');
          setStatus('内容编辑器加载失败，请检查网络后刷新重试。', true);
        });
        document.body.appendChild(script);
      }

      function relayStoredAuthMessage() {
        let saved = null;
        try {
          saved = JSON.parse(localStorage.getItem(authBridgeKey) || 'null');
        } catch (error) {
          localStorage.removeItem(authBridgeKey);
        }

        if (!saved?.message || Date.now() - saved.createdAt > 10 * 60 * 1000) {
          localStorage.removeItem(authBridgeKey);
          return;
        }

        let attempts = 0;
        const timer = window.setInterval(() => {
          window.postMessage(saved.message, window.location.origin);
          attempts += 1;
          if (attempts >= 24) {
            window.clearInterval(timer);
            localStorage.removeItem(authBridgeKey);
          }
        }, 250);
      }

      function installCmsTheme() {
        let style = document.querySelector('style[data-cms-matte-theme]');
        if (!style) {
          style = document.createElement('style');
          style.setAttribute('data-cms-matte-theme', '');
          document.head.appendChild(style);
        }

        style.textContent = `
          body.unlocked *,
          body.unlocked *::before,
          body.unlocked *::after {
            box-shadow: none !important;
            text-shadow: none !important;
          }

          body.unlocked button,
          body.unlocked .sui.button,
          body.unlocked [role="button"] {
            background-image: none !important;
            filter: none !important;
          }

          body.unlocked input,
          body.unlocked textarea,
          body.unlocked select {
            max-width: 100% !important;
            font-size: 16px !important;
          }

          body.unlocked [role="dialog"],
          body.unlocked dialog {
            max-width: calc(100vw - 1rem) !important;
          }

          body.unlocked button.sui.button.primary,
          body.unlocked .sui.button.primary {
            border-color: rgba(217, 168, 96, 0.72) !important;
            background-color: #d9a860 !important;
            color: #17100a !important;
          }

          body.unlocked button.sui.button.secondary,
          body.unlocked .sui.button.secondary {
            border-color: rgba(244, 234, 220, 0.18) !important;
            background-color: #181612 !important;
            color: rgba(244, 234, 220, 0.82) !important;
          }

          body.unlocked button.sui.button.primary *,
          body.unlocked .sui.button.primary * {
            color: #17100a !important;
          }

          body.unlocked button.sui.button.secondary *,
          body.unlocked .sui.button.secondary * {
            color: rgba(244, 234, 220, 0.82) !important;
          }

          body.unlocked img.logo[src^="data:image/svg+xml"] {
            display: none !important;
          }

          @media (max-width: 640px) {
            body.unlocked {
              overflow-x: hidden !important;
            }

            body.unlocked .sui.button,
            body.unlocked button {
              min-height: 42px !important;
            }
          }
        `;
      }

      if (sessionStorage.getItem(sessionKey) === '1') {
        loadCms();
      }

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        const value = input?.value || '';

        if (!value.trim()) {
          setStatus('请输入管理员密码。', true);
          input?.focus();
          return;
        }

        submit.disabled = true;
        setStatus('正在验证...');

        try {
          const hash = await sha256(value);
          if (hash !== passwordHash) {
            setStatus('密码不对，请重新输入。', true);
            input?.select();
            return;
          }

          sessionStorage.setItem(sessionKey, '1');
          setStatus('验证通过，正在加载后台...');
          loadCms();
        } catch (error) {
          setStatus('当前浏览器不支持安全校验，请换一个现代浏览器。', true);
        } finally {
          submit.disabled = false;
        }
      });
    </script>
  </body>
</html>
