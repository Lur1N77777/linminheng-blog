---
import { render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { profile } from '../../data/profile';
import { richText } from '../../utils/richText';
import {
  formatPostDate,
  getAdjacentPosts,
  getPostUrl,
  getPublishedPosts,
  getReadingTime,
  type BlogPost,
} from '../../utils/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post, posts },
  }));
}

const { post, posts } = Astro.props as { post: BlogPost; posts: BlogPost[] };
const { Content } = await render(post);
const nav = getAdjacentPosts(posts, post);
const updated = post.data.updated ? formatPostDate(post.data.updated) : undefined;
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const articleUrl = new URL(getPostUrl(post), siteUrl).toString();
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.excerpt,
  url: articleUrl,
  datePublished: post.data.date.toISOString(),
  dateModified: (post.data.updated ?? post.data.date).toISOString(),
  inLanguage: 'zh-CN',
  author: {
    '@type': 'Person',
    name: profile.name,
  },
  publisher: {
    '@type': 'Person',
    name: profile.name,
  },
  mainEntityOfPage: articleUrl,
  keywords: post.data.tags.join(', '),
  ...(post.data.cover ? { image: new URL(post.data.cover, siteUrl).toString() } : {}),
};
---

<Base
  profile={profile}
  layout="single"
  bodyClass="article-page"
  title={`${post.data.title} — ${profile.name}`}
  description={post.data.excerpt}
  image={post.data.cover}
  canonical={getPostUrl(post)}
  ogType="article"
  showReadingProgress
  jsonLd={articleJsonLd}
>
  <main class="single-page">
    <article class="article-shell">
      <header class="article-hero" data-intro style="--i:0">
        <a class="back-link" href="/blog/">返回博文</a>
        <div class="article-meta">
          <span>{formatPostDate(post.data.date)}</span>
          {updated && <span>更新于 {updated}</span>}
          <span>{getReadingTime(post)}</span>
        </div>
        <h1 class="article-title">{post.data.title}</h1>
        <p class="article-excerpt" set:html={richText(post.data.excerpt)}></p>
        <div class="post-tags">{post.data.tags.map((tag) => <span class="tag">{tag}</span>)}</div>
      </header>

      {post.data.cover && (
        <figure class="article-cover" data-reveal>
          <img src={post.data.cover} alt="" loading="eager" decoding="async" fetchpriority="high" />
        </figure>
      )}

      <div class="article-content prose" data-reveal>
        <Content />
        {post.data.foot && <p class="post-foot" set:html={richText(post.data.foot)}></p>}
      </div>
    </article>

    <nav class="article-nav" aria-label="文章导航" data-reveal>
      {nav.previous ? (
        <a href={getPostUrl(nav.previous)}>
          <span>上一篇</span>
          <strong>{nav.previous.data.title}</strong>
        </a>
      ) : (
        <span></span>
      )}
      {nav.next ? (
        <a href={getPostUrl(nav.next)}>
          <span>下一篇</span>
          <strong>{nav.next.data.title}</strong>
        </a>
      ) : (
        <span></span>
      )}
    </nav>
  </main>
</Base>
