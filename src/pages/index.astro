---
import Base from '../layouts/Base.astro';
import { experiences } from '../data/experiences';
import { about, profile } from '../data/profile';
import { githubProfile, projects } from '../data/projects';
import { sites } from '../data/sites';
import { richText } from '../utils/richText';
import { formatPostDate, getPostUrl, getPublishedPosts, getReadingTime } from '../utils/posts';

const posts = (await getPublishedPosts()).slice(0, 3);
const { socials } = profile;
const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const homeUrl = new URL('/', siteUrl).toString();
const sameAs = [socials.github, socials.instagram].filter(Boolean);
const homeJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: profile.name,
    url: homeUrl,
    jobTitle: profile.title,
    email: socials.email ? `mailto:${socials.email}` : undefined,
    sameAs,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: profile.name,
    url: homeUrl,
    description: profile.tagline.replace(/<[^>]*>/g, ''),
    inLanguage: 'zh-CN',
    author: {
      '@type': 'Person',
      name: profile.name,
    },
  },
].map((item) => JSON.parse(JSON.stringify(item)));
---

<Base profile={profile} jsonLd={homeJsonLd}>
  <!-- ================= 左:个人名片 ================= -->
  <header class="col-left">
    <div>
      <h1 class="name" data-intro style="--i:0">{profile.name}</h1>
      <p class="title" data-intro style="--i:1">{profile.title}</p>
      <p class="tagline" data-intro style="--i:2" set:html={richText(profile.tagline)}></p>

      <nav id="nav">
        <a class="nav-link" href="#about" data-intro style="--i:3"><span class="nav-line"></span>关于</a>
        <a class="nav-link" href="#experience" data-intro style="--i:4"><span class="nav-line"></span>历程</a>
        <a class="nav-link" href="#projects" data-intro style="--i:5"><span class="nav-line"></span>项目</a>
        <a class="nav-link" href="#sites" data-intro style="--i:6"><span class="nav-line"></span>站点</a>
        <a class="nav-link" href="#writing" data-intro style="--i:7"><span class="nav-line"></span>博文</a>
      </nav>
    </div>

    <div class="profile-footer">
      <div class="socials" data-intro style="--i:8">
        {socials.github && (
          <a href={socials.github} target="_blank" rel="noopener" aria-label="GitHub" title="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.8 10.9.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.8-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.5-1.5 7.8-5.8 7.8-10.9C23.5 5.7 18.3.5 12 .5z"/></svg>
          </a>
        )}
        {socials.instagram && (
          <a href={socials.instagram} target="_blank" rel="noopener" aria-label="Instagram" title="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
        )}
        {socials.email && (
          <a href={`mailto:${socials.email}`} aria-label="Email" title="邮箱">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
          </a>
        )}
      </div>
      <p class="foot" data-intro style="--i:9" set:html={richText(profile.foot)}></p>
      <p class="visitor-stat" data-intro style="--i:10" data-visitor-stat hidden>
        访客 <span data-visitor-count>--</span>
      </p>
    </div>
  </header>

  <!-- ================= 右:内容流 ================= -->
  <main class="col-right">

    <!-- 关于 -->
    <section id="about">
      <div class="section-label">关于</div>
      <div class="prose" data-reveal>
        {about.map((para) => <p set:html={richText(para)}></p>)}
      </div>
    </section>

    <!-- 历程 -->
    <section id="experience">
      <div class="section-label">历程</div>
      <div class="cards">
        {experiences.map((exp) => (
          exp.href ? (
            <a class="card row" data-reveal href={exp.href} target="_blank" rel="noopener">
              <div class="card-meta">{exp.meta}</div>
              <div>
                <div class="card-title">{exp.title} <span class="arrow">↗</span></div>
                <div class="card-desc" set:html={richText(exp.desc)}></div>
                <div class="tags">{exp.tags.map((t) => <span class="tag">{t}</span>)}</div>
              </div>
            </a>
          ) : (
            <div class="card row" data-reveal>
              <div class="card-meta">{exp.meta}</div>
              <div>
                <div class="card-title">{exp.title}</div>
                <div class="card-desc" set:html={richText(exp.desc)}></div>
                <div class="tags">{exp.tags.map((t) => <span class="tag">{t}</span>)}</div>
              </div>
            </div>
          )
        ))}
      </div>
    </section>

    <!-- 项目 -->
    <section id="projects">
      <div class="section-label">项目</div>
      <div class="cards">
        {projects.map((proj) => (
          <a
            class="card project"
            data-reveal
            href={proj.href}
            target="_blank"
            rel="noopener"
            data-repo={proj.repo}
            data-stars={proj.stars}
          >
            <div class="thumb">
              {proj.logo ? <img src={proj.logo} alt={`${proj.name} logo`} width="256" height="192" loading="lazy" decoding="async" /> : proj.name}
            </div>
            <div>
              <div class="card-title">{proj.name} <span class="arrow">↗</span></div>
              <div class="card-desc" set:html={richText(proj.desc)}></div>
              <div class="tags">
                {proj.repo && (
                  <span class="tag star" title="GitHub Stars">★ <span class="star-num">{proj.stars}</span></span>
                )}
                {proj.tags.map((t) => <span class="tag">{t}</span>)}
              </div>
            </div>
          </a>
        ))}
      </div>
      <p class="prose" style="margin-top:1.5rem" data-reveal>
        <a class="link-accent" href={githubProfile} target="_blank" rel="noopener">在 GitHub 上看全部 →</a>
      </p>
    </section>

    <!-- 站点 -->
    <section id="sites">
      <div class="section-label">站点</div>
      <div class="cards">
        {sites.map((site) => (
          <a class="card project" data-reveal href={site.href} target="_blank" rel="noopener">
            <div class="thumb">
              {site.logo ? <img src={site.logo} alt={`${site.name} logo`} width="256" height="192" loading="lazy" decoding="async" /> : site.name}
            </div>
            <div>
              <div class="card-title">{site.name} <span class="arrow">↗</span></div>
              <div class="card-desc" set:html={richText(site.desc)}></div>
              <div class="tags">{site.tags.map((t) => <span class="tag">{t}</span>)}</div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- 博文 -->
    <section id="writing">
      <div class="section-head" data-reveal>
        <div class="section-label">博文</div>
        <a class="section-action" href="/blog/">全部文章</a>
      </div>
      <div class="posts">
        {posts.map((post) => (
          <article class="post" data-reveal>
            <a class="post-head post-link" href={getPostUrl(post)}>
              <div class="post-main">
                <div class="post-date">{formatPostDate(post.data.date)} · {getReadingTime(post)}</div>
                <h3 class="post-title">{post.data.title}</h3>
                <p class="post-excerpt" set:html={richText(post.data.excerpt)}></p>
                <div class="post-tags">{post.data.tags.map((t) => <span class="tag">{t}</span>)}</div>
              </div>
              <span class="read-more" aria-hidden="true">阅读全文</span>
            </a>
          </article>
        ))}
      </div>
    </section>

  </main>
</Base>
